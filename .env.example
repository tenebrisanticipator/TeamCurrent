DATABASE_URL=your_neondb_connection_string
JWT_SECRET=your_jwt_secret
# AES_SECRET_KEY: 64 hex characters (32 bytes for AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_SECRET_KEY=your_64_hex_character_aes_key_example0123456789abcdef0123456789abcdef
# AES_IV: 32 hex characters (16 bytes for AES-256-CBC)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
AES_IV=your_32_hex_character_iv_example0123456789abcdef
